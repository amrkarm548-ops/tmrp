// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - role: string ('admin' | 'user')
//   - settings: map (defaultStudyMode, preferredLanguage)
//   - feedback: list (strings)
//   - createdAt: timestamp
//
// Collection: files
// Document ID: {fileId}
// Fields:
//   - id: string (required)
//   - title: string (required)
//   - type: string
//   - content: string (required)
//   - createdAt: timestamp
//   - createdBy: string (uid)
//   - category: string
//
// Collection: config
// Document ID: global
// Fields:
//   - dynamicPromptTuning: string
//   - totalUsers: number
//   - totalFiles: number
//
// Collection: tamrediano_library
// Document ID: {itemId}
// Fields:
//   - id: string
//   - name: string
//   - type: string ('folder' | 'file')
//   - parentId: string
//   - url: string
//   - mimeType: string
//   - createdAt: timestamp
//   - createdBy: string
//
// Collection: api_keys
// Document ID: {keyId}
// Fields:
//   - id: string
//   - key: string
//   - addedBy: string
//   - usageCount: number
//   - status: string
//   - createdAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "nkarm396@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidFile(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'createdBy']) &&
             data.id is string &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 1000000 &&
             data.createdBy == request.auth.uid;
    }

    function isValidLibraryItem(data) {
      return data.keys().hasAll(['name', 'type', 'parentId', 'createdBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['folder', 'file'] &&
             data.parentId is string &&
             data.createdBy == request.auth.uid;
    }

    function isValidApiKey(data) {
      return data.keys().hasAll(['key', 'addedBy', 'status']) &&
             data.key is string &&
             data.addedBy is string &&
             data.status in ['active', 'exhausted', 'invalid'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) || isAdmin();
    }

    match /files/{fileId} {
      // Files are public for download as requested
      allow read: if true; 
      allow create: if isAuthenticated() && isValidFile(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    match /config/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tamrediano_library/{itemId} {
      // accessible and creatable by any authenticated user
      allow read: if true;
      allow create: if isAuthenticated() && isValidLibraryItem(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    match /tamrediano_library_chunks/{chunkId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    match /api_keys/{keyId} {
      allow read: if isAuthenticated(); // So the edge functions / services can read
      allow create, update, delete: if isAdmin() || isAuthenticated(); // anyone can update usage
    }

    match /prompt_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
  }
}
